// Prisma schema for the Jobber home-services marketplace
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Every account can both post missions and apply to them — MANAGER/JOBBER
// are no longer exclusive gates, just the default label shown at signup.
enum Role {
  MANAGER
  JOBBER
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  APPROVED
  REJECTED
}

enum MissionStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum BookingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  REQUIRES_PAYMENT
  HELD_IN_ESCROW
  RELEASED
  REFUNDED
  FAILED
}

enum DocumentType {
  ID_CARD
  PROOF_OF_ADDRESS
  BANK_ACCOUNT
  DIPLOMA
}

enum PayoutStatus {
  PENDING
  COMPLETED
  FAILED
}

enum SkillLevel {
  PROFESSIONNEL
  EXPERT
  PASSIONNE
}

enum SubscriptionPlan {
  MANAGER_BOSS
  MANAGER_HOLDER
  ENTERPRISE_20
  ENTERPRISE_50
  ENTERPRISE_UNLIMITED
  JOBBER_SILVER
  JOBBER_GOLD
  JOBBER_PLATINUM
}

// An individual account can be both a manager (posting missions) and a
// jobber (applying to them) at once, so it may hold one active MANAGER-side
// subscription (waives the poster's fee) AND one active JOBBER-side
// subscription (waives the provider's fee) simultaneously — family is what
// the @@unique([userId, family]) below is keyed on.
enum SubscriptionFamily {
  MANAGER
  JOBBER
}

// Every account is INDIVIDUAL by default (can both post missions and
// candidater — see the User model). COMPANY accounts ("Recrutez vos
// collaborateurs à la tâche") can only post/manage missions, never apply
// to them — no providerProfile is created for them at signup.
enum AccountKind {
  INDIVIDUAL
  COMPANY
}

// ENTREPRISE: recruits directly for its own operational needs (packing,
// unloading trucks, site cleanup…). CORPORATE: a home-services company
// subcontracting its own client-facing service delivery to Jobber. Purely
// a self-declared badge — both have identical permissions/fees.
enum CompanyType {
  ENTREPRISE
  CORPORATE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

enum VehicleType {
  VOITURE_TOURISME
  MINIBUS
  CAMION_BENNE
  REMORQUE
  GRANDE_REMORQUE
  PETIT_UTILITAIRE_4M3
  FOURGONNETTE_9M3
  CAMION_15M3
  GRAND_CAMION_20M3
  POIDS_LOURD
  CAMION_PLATEAU
  REMORQUE_BATEAU
}

enum RecurrenceUnit {
  JOUR
  SEMAINE
  MOIS
  AN
}

enum MissionType {
  TASK
  LESSON
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  passwordHash      String?
  firstName         String
  lastName          String
  phone             String?
  role              Role       @default(MANAGER)
  accountKind       AccountKind @default(INDIVIDUAL)
  companyType       CompanyType?
  companyName       String?
  companySiret      String?    @unique
  avatarUrl         String?
  address           String?
  lat               Float?
  lng               Float?
  isEmailVerified   Boolean    @default(false)
  resetToken           String?   @unique
  resetTokenExpiresAt  DateTime?
  googleId             String?   @unique
  stripeCustomerId     String?   @unique
  creditBalance        Float     @default(0)
  referralCode         String?   @unique
  referredById         String?
  referredBy           User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals            User[]    @relation("Referrals")
  referralEarned       Float     @default(0)
  notifyPushNews          Boolean @default(true)
  notifyEmailNews         Boolean @default(true)
  notifyEmailPartners     Boolean @default(true)
  notifySmsOffers         Boolean @default(false)
  notifySmsCancellation   Boolean @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  providerProfile   ProviderProfile?
  subscriptions     Subscription[]
  missions          Mission[]        @relation("ClientMissions")
  offers            Offer[]          @relation("ProviderOffers")
  bookingsAsClient  Booking[]        @relation("ClientBookings")
  bookingsAsProvider Booking[]       @relation("ProviderBookings")
  sentMessages      Message[]        @relation("SentMessages")
  reviewsWritten    Review[]         @relation("ReviewAuthor")
  reviewsReceived   Review[]         @relation("ReviewTarget")
  documents         VerificationDocument[]
  conversationsAsClient   Conversation[] @relation("ConvClient")
  conversationsAsProvider Conversation[] @relation("ConvProvider")
  favoritesAsManager  Favorite[] @relation("FavoritesByManager")
  favoritedAsProvider Favorite[] @relation("FavoritedProvider")
}

// A manager bookmarking a jobber they'd like to work with again ("Mes
// jobbers favoris") — independent of whether a booking ever happened, so
// it also works for providers found via /providers browsing.
model Favorite {
  id         String   @id @default(cuid())
  managerId  String
  manager    User     @relation("FavoritesByManager", fields: [managerId], references: [id])
  providerId String
  provider   User     @relation("FavoritedProvider", fields: [providerId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([managerId, providerId])
}

// "Plus aucun frais" for the manager (MANAGER_BOSS/HOLDER, ENTERPRISE_*)
// waives the poster-side booking fee up to the plan's monthly mission
// quota; the JOBBER_* family does the same for the provider-side fee. One
// user can hold at most one ACTIVE subscription per family at a time (see
// @@unique below) — see offers.routes.js acceptOffer for where this is spent.
model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id])
  family               SubscriptionFamily @default(MANAGER)
  plan                 SubscriptionPlan
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?            @unique
  currentPeriodStart   DateTime           @default(now())
  currentPeriodEnd     DateTime
  missionsUsedInPeriod Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([userId, family])
}

model ProviderProfile {
  id                  String              @id @default(cuid())
  userId              String              @unique
  user                User                @relation(fields: [userId], references: [id])
  radiusKm            Int                 @default(15)
  verificationStatus  VerificationStatus  @default(UNVERIFIED)
  ratingAverage       Float               @default(0)
  ratingCount         Int                 @default(0)
  completedMissions   Int                 @default(0)
  walletBalance       Float               @default(0)
  autoApply           Boolean             @default(false)
  offersLessons       Boolean             @default(false)
  stripeAccountId     String?             @unique
  payoutsEnabled      Boolean             @default(false)
  bankLast4           String?
  bankHolderName      String?
  autoPayout          Boolean             @default(false)
  siret               String?             @unique
  categories          ProviderCategory[]
  services            ProviderService[]
  equipment           ProviderEquipment[]
  vehicles            ProviderVehicle[]
  payouts             Payout[]
  createdAt           DateTime            @default(now())
}

// A jobber's request to move their wallet balance to their bank account.
// Money moves via Stripe Connect (Custom account) behind the scenes, but the
// jobber never sees a Stripe-branded page — everything is collected and
// triggered from our own UI.
model Payout {
  id               String       @id @default(cuid())
  providerId       String
  provider         ProviderProfile @relation(fields: [providerId], references: [id])
  amount           Float
  status           PayoutStatus @default(PENDING)
  stripeTransferId String?
  stripePayoutId   String?      @unique
  failureReason    String?
  createdAt        DateTime     @default(now())
  completedAt      DateTime?
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String?
  services    Service[]
  equipment   Equipment[]
  missions    Mission[]
  providers   ProviderCategory[]
}

// A piece of equipment/tooling typically needed for a category — the jobber
// checks off which of these they personally own ("Matériel que je possède").
model Equipment {
  id          String   @id @default(cuid())
  name        String
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  providers   ProviderEquipment[]
  missions    MissionEquipment[]

  @@unique([categoryId, name])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  missions    Mission[]
  providers   ProviderService[]
  // Extra structured fields to collect at mission-publishing time for this
  // service, e.g. [{ key: 'surfaceM2', label: 'Surface', type: 'number',
  // unit: 'm²' }] — rendered dynamically, answers stored on Mission.details.
  detailFields Json?
}

// One row per main category a jobber has picked, carrying their declared
// skill level for that whole category (sub-service picks live separately
// in ProviderService).
model ProviderCategory {
  id         String     @id @default(cuid())
  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  categoryId String
  category   Category   @relation(fields: [categoryId], references: [id])
  level      SkillLevel @default(PASSIONNE)
  hourlyRate Float      @default(15)
  bio        String?

  @@unique([providerId, categoryId])
}

// Sub-category (Service) skills a jobber has checked off within a category.
model ProviderService {
  id         String   @id @default(cuid())
  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id])

  @@unique([providerId, serviceId])
}

// Equipment a jobber has checked off as owned within a category
// ("Matériel que je possède").
model ProviderEquipment {
  id          String    @id @default(cuid())
  providerId  String
  provider    ProviderProfile @relation(fields: [providerId], references: [id])
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  @@unique([providerId, equipmentId])
}

// A vehicle type the jobber has access to for missions requiring transport
// ("Mes véhicules") — a fixed global list, not tied to a skill category.
model ProviderVehicle {
  id         String      @id @default(cuid())
  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  type       VehicleType

  @@unique([providerId, type])
}

model Mission {
  id             String        @id @default(cuid())
  type           MissionType   @default(TASK)
  clientId       String
  client         User          @relation("ClientMissions", fields: [clientId], references: [id])
  categoryId     String
  category       Category      @relation(fields: [categoryId], references: [id])
  serviceId      String?
  service        Service?      @relation(fields: [serviceId], references: [id])
  title          String
  description    String
  address        String
  lat            Float?
  lng            Float?
  // Only set for transport-type missions (déménagement, convoi, transport):
  // `address`/`lat`/`lng` above act as the departure point, and these
  // describe the arrival point so a route can be drawn between the two.
  dropoffAddress String?
  dropoffLat     Float?
  dropoffLng     Float?
  photos         String[]      @default([])
  desiredDate    DateTime
  estimatedHours Float         @default(1)
  isUrgent       Boolean       @default(false)
  datesFlexible  Boolean       @default(false)
  isRecurring     Boolean         @default(false)
  recurrenceCount Int?
  recurrenceUnit  RecurrenceUnit?
  requiredVehicleTypes VehicleType[] @default([])
  otherVehicleNote     String?
  otherEquipmentNote   String?
  // Company-only options (silently ignored server-side for individual
  // accounts). Multi-day: desiredDate is the start, missionEndDate the end.
  missionEndDate             DateTime?
  equipmentProvidedByCompany Boolean?
  ppeProvidedByCompany       Boolean?
  requiredPpe                String[]  @default([])
  requiresMachine            Boolean?
  requiredMachines           String[]  @default([])
  // Answers to the selected service's detailFields (e.g. { hedgeHeightM: 1.5,
  // hedgeLengthM: 12 }) — keyed by field key, shape defined per-service.
  details        Json?
  status         MissionStatus @default(OPEN)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  offers            Offer[]
  booking           Booking?
  conversations     Conversation[]
  requiredEquipment MissionEquipment[]
}

// Equipment the client is asking the jobber to bring for this specific
// mission — distinct from ProviderEquipment (what a jobber owns overall).
model MissionEquipment {
  id          String    @id @default(cuid())
  missionId   String
  mission     Mission   @relation(fields: [missionId], references: [id])
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  @@unique([missionId, equipmentId])
}

model Offer {
  id          String      @id @default(cuid())
  missionId   String
  mission     Mission     @relation(fields: [missionId], references: [id])
  providerId  String
  provider    User        @relation("ProviderOffers", fields: [providerId], references: [id])
  hourlyRate  Float
  message     String?
  status      OfferStatus @default(PENDING)
  createdAt   DateTime    @default(now())

  @@unique([missionId, providerId])
}

model Booking {
  id             String        @id @default(cuid())
  missionId      String        @unique
  mission        Mission       @relation(fields: [missionId], references: [id])
  offerId        String        @unique
  clientId       String
  client         User          @relation("ClientBookings", fields: [clientId], references: [id])
  providerId     String
  provider       User          @relation("ProviderBookings", fields: [providerId], references: [id])
  scheduledDate  DateTime
  hours          Float
  hourlyRate     Float
  totalAmount    Float
  status         BookingStatus @default(SCHEDULED)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  payment        Payment?
  review         Review?
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @unique
  booking               Booking       @relation(fields: [bookingId], references: [id])
  stripePaymentIntentId String?
  amount                Float
  platformFee           Float
  managerFee            Float         @default(2)
  providerFee           Float         @default(2)
  feeWaived             Boolean       @default(false)
  providerPayout        Float
  status                PaymentStatus @default(REQUIRES_PAYMENT)
  paidAt                DateTime?
  releasedAt            DateTime?
  createdAt             DateTime      @default(now())
}

model Conversation {
  id          String     @id @default(cuid())
  missionId   String
  mission     Mission    @relation(fields: [missionId], references: [id])
  clientId    String
  client      User       @relation("ConvClient", fields: [clientId], references: [id])
  providerId  String
  provider    User       @relation("ConvProvider", fields: [providerId], references: [id])
  messages    Message[]
  createdAt   DateTime   @default(now())

  @@unique([missionId, providerId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  content        String
  readAt         DateTime?
  createdAt      DateTime     @default(now())
}

model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])
  authorId   String
  author     User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetId   String
  target     User     @relation("ReviewTarget", fields: [targetId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
}

model VerificationDocument {
  id         String              @id @default(cuid())
  userId     String
  user       User                @relation(fields: [userId], references: [id])
  type       DocumentType
  fileUrl    String
  status     VerificationStatus  @default(PENDING)
  reviewedAt DateTime?
  createdAt  DateTime            @default(now())
}
